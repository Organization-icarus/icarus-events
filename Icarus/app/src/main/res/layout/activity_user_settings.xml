<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:id="@+id/user_settings_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Settings"
        android:textColor="@color/primary_container_highlighted"
        android:textSize="@dimen/font_super_heading_size"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/user_settings_profile_image"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.498"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.751" />

    <Switch
        android:id="@+id/user_settings_admin_notifications_switch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:text="Administrator Notifcations"
        app:layout_constraintBottom_toTopOf="@+id/user_settings_org_notifications_switch"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.498"
        app:layout_constraintStart_toStartOf="parent" />

    <Switch
        android:id="@+id/user_settings_org_notifications_switch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp"
        android:text="Organizer Notifications"
        app:layout_constraintBottom_toTopOf="@+id/user_profile_delete_button"
        tools:layout_editor_absoluteX="110dp" />

    <Button
        android:id="@+id/user_profile_delete_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="284dp"
        android:backgroundTint="@color/attention"
        android:text="Delete Profile"
        android:textColor="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Included nav bar -->
    <ImageView
        android:id="@+id/user_settings_profile_image"
        android:layout_width="88dp"
        android:layout_height="105dp"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toTopOf="@+id/user_settings_admin_notifications_switch"
        app:srcCompat="@drawable/profile"
        tools:layout_editor_absoluteX="161dp" />

    <include
        android:id="@+id/nav_bar"
        layout="@layout/nav_bar"
        android:layout_width="0dp"
        android:layout_height="60dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>