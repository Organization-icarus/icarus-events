<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- -->
    <!-- For full-width buttons -->
    <!-- -->
    <style name="AppButton" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:textSize">@dimen/font_text_size</item>
        <item name="android:textColor">@color/darkText</item>
        <item name="backgroundTint">@color/accent_first</item>
        <item name="cornerRadius">0dp</item>
        <item name="iconTint">@color/black</item>
        <item name="iconPadding">8dp</item>
        <item name="android:padding">0dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="iconGravity">start</item>
        <item name="android:gravity">start|center_vertical</item>
    </style>


    <!-- -->
    <!-- For the event banner -->
    <!-- -->
    <style name="EventBannerImageShape">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">16dp</item>
        <item name="cornerSizeTopRight">16dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>


    <!-- -->
    <!-- For cards to wrap views -->
    <!-- -->
    <style name="ViewCard">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>

        <item name="contentPadding">12dp</item>

        <item name="cardElevation">0dp</item>
        <item name="cardCornerRadius">8dp</item>
        <item name="strokeColor">#313131</item>
        <item name="strokeWidth">2dp</item>
        <item name="cardBackgroundColor">#313131</item>
    </style>


    <!-- -->
    <!-- For linear layouts inside top-level scroll views -->
    <!-- -->
    <style name="LinearLayoutForNavBar">
        <!-- Layout -->
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <!-- Orientation -->
        <item name="android:orientation">vertical</item>
        <!-- Padding -->
        <item name="android:paddingStart">@dimen/side_padding</item>
        <item name="android:paddingEnd">@dimen/side_padding</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">@dimen/nav_bar_height_plus_padding</item>
        <!-- Behavior -->
        <item name="android:clipToPadding">false</item>
        <item name="android:gravity">center_horizontal</item>
    </style>

    <!-- -->
    <!-- For framing profile pictures in circles -->
    <!-- -->
    <style name="ShapeAppearanceOverlay.App.CircleImageView" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

</resources>