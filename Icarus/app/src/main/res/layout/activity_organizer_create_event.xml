<?xml version="1.0" encoding="utf-8"?>
    <androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F5F3FA">

        <TextView
            android:id="@+id/OrganizerCreateEventTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:text="Create Event"
            android:textColor="#1A1A2E"
            android:textSize="@dimen/font_heading_size"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <Button
            android:id="@+id/OrganizerCreateEventUploadPosterButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:backgroundTint="@color/primary_container"
            android:drawablePadding="8dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:text="Upload Event Poster"
            android:textSize="@dimen/font_text_size"
            android:textColor="@color/primary_container_highlighted"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/OrganizerCreateEventTitle"/>

        <Button
            android:id="@+id/OrganizerCreateEventLimitWaitingListLimitButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="64dp"
            android:text="Optional Waiting List Limit"
            android:textSize="@dimen/font_text_size"
            android:backgroundTint="@color/primary_container"
            android:textColor="@color/primary_container_highlighted"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/OrganizerCreateEventUploadPosterButton"/>

        <Button
            android:id="@+id/OrganizerCreateEventRegistrationPeriodStart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="64dp"
            android:text="Registration Period Start"
            android:textSize="@dimen/font_text_size"
            android:backgroundTint="@color/primary_container"
            android:textColor="@color/primary_container_highlighted"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/OrganizerCreateEventLimitWaitingListLimitButton"/>

        <Button
            android:id="@+id/OrganizerCreateEventRegistrationPeriodEnd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="64dp"
            android:text="Registration Period End"
            android:textSize="@dimen/font_text_size"
            android:backgroundTint="@color/primary_container"
            android:textColor="@color/primary_container_highlighted"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/OrganizerCreateEventRegistrationPeriodStart"/>
        <Button
            android:id="@+id/OrganizerCreateEventCreateEvent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="64dp"
            android:text="Create Event"
            android:textSize="@dimen/font_text_size"
            android:backgroundTint="@color/primary_container"
            android:textColor="@color/primary_container_highlighted"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/OrganizerCreateEventRegistrationPeriodEnd"/>


        <include
            android:id="@+id/nav_bar"
            layout="@layout/nav_bar"
            android:layout_width="0dp"
            android:layout_height="60dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>