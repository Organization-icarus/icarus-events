<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/OrganizerEntrantTitleCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp"
        app:cardElevation="0dp"
        app:cardCornerRadius="8dp"
        app:strokeColor="@color/primary_container"
        app:strokeWidth="2dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <TextView
                android:id="@+id/OrganizerEntrantNameOnViewList"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:textSize="@dimen/font_subheading_size"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:gravity="start|center_vertical"
                android:text="Entrant Name"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <TextView
                android:id="@+id/OrganizerEntrantPhoneOnViewList"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textSize="@dimen/font_text_size"
                android:textColor="@color/black"
                android:gravity="start|center_vertical"
                android:text="Phone: Not Given"
                app:layout_constraintTop_toBottomOf="@id/OrganizerEntrantNameOnViewList"
                app:layout_constraintStart_toEndOf="@id/OrganizerEntrantEmailOnViewList"
                app:layout_constraintEnd_toEndOf="parent"/>

            <TextView
                android:id="@+id/OrganizerEntrantEmailOnViewList"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textSize="@dimen/font_text_size"
                android:textColor="@color/black"
                android:gravity="start|center_vertical"
                android:text="Email: Not Given"
                app:layout_constraintTop_toTopOf="@id/OrganizerEntrantPhoneOnViewList"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/OrganizerEntrantPhoneOnViewList"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>
    <TextView
        android:id="@+id/OrganizerEntrantSpacerOnViewList"
        android:layout_width="match_parent"
        android:layout_height="16dp"
        app:layout_constraintTop_toBottomOf="@id/OrganizerEntrantTitleCard"/>

</androidx.constraintlayout.widget.ConstraintLayout>