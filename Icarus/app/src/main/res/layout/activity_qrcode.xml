<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            style="@style/LinearLayoutForNavBar"
            android:gravity="center">

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scan QR Code"
                android:textSize="@dimen/font_heading_size"
                android:textColor="@color/lightText"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"
                android:layout_gravity="center_horizontal" />

            <!-- Camera Preview Placeholder -->
            <com.google.android.material.card.MaterialCardView
                style="@style/ViewCard"
                android:layout_marginBottom="12dp"
                android:layout_gravity="center_horizontal"
                app:cardCornerRadius="16dp"
                android:background="@color/accent_first"
                app:strokeColor="@color/accent_first">

                <FrameLayout
                    android:id="@+id/camera_preview"
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    android:background="@color/secondary" />

            </com.google.android.material.card.MaterialCardView>

            <!-- Instruction Text -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Point your camera at an event QR code"
                android:textSize="@dimen/font_subheading_size"
                android:textColor="@color/lightTextSemi"
                android:layout_gravity="center_horizontal" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- NAVIGATION BAR -->
    <include
        android:id="@+id/nav_bar"
        layout="@layout/nav_bar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/nav_bar_height"
        android:layout_gravity="bottom" />

</FrameLayout>