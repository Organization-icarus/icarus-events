<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/secondary">

    <TextView
        android:id="@+id/dialog_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Lottery Guidelines"
        android:textColor="@color/lightText"
        android:textStyle="bold"
        android:textSize="@dimen/font_subheading_size"
        android:paddingBottom="12dp" />

    <TextView
        android:id="@+id/dialog_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/lottery_guidelines_message"
        android:textColor="@color/lightTextSemi"
        android:textSize="@dimen/font_text_size"
        android:paddingBottom="20dp" />

    <Button
        android:id="@+id/dialog_ok_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:text="OK"
        android:textColor="@color/accent_first"
        android:background="@android:color/transparent" />
</LinearLayout>