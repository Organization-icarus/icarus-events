<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/primary"
    android:padding="16dp">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="36dp"
        android:background="@color/primary_container"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:id="@+id/backButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="‹"
            android:textColor="@color/black"
            android:textSize="@dimen/font_heading_size"
            android:textStyle="normal" />

        <TextView
            android:id="@+id/titleText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Sample Attendees"
            android:textColor="@color/black"
            android:textSize="@dimen/font_heading_size"
            android:textStyle="normal" />

        <TextView
            android:id="@+id/topRightIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="◉"
            android:textColor="@color/black"
            android:textSize="@dimen/font_text_size"
            android:textStyle="normal" />
    </LinearLayout>

    <!-- Subtitle -->
    <TextView
        android:id="@+id/subtitleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="18dp"
        android:background="@color/primary_container"
        android:paddingStart="14dp"
        android:paddingTop="6dp"
        android:paddingEnd="14dp"
        android:paddingBottom="6dp"
        android:text="Number to Invite"
        android:textColor="@color/black"
        android:textSize="@dimen/font_text_size"
        android:textStyle="normal" />

    <!-- Number selector -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="28dp"
        android:background="@color/primary_container"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <TextView
            android:id="@+id/attendeeCountText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="10"
            android:textColor="@color/black"
            android:textSize="@dimen/font_text_size"
            android:textStyle="normal" />

        <Button
            android:id="@+id/plusButton"
            android:layout_width="40dp"
            android:layout_height="32dp"
            android:backgroundTint="@color/primary_container"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            android:text="+"
            android:textAllCaps="false"
            android:textColor="@color/black"
            android:textSize="@dimen/font_text_size"
            android:textStyle="normal" />

        <Button
            android:id="@+id/minusButton"
            android:layout_width="40dp"
            android:layout_height="32dp"
            android:backgroundTint="@color/primary_container"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            android:text="-"
            android:textAllCaps="false"
            android:textColor="@color/black"
            android:textSize="@dimen/font_text_size"
            android:textStyle="normal" />
    </LinearLayout>

    <!-- Action buttons -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:orientation="horizontal">

        <Button
            android:id="@+id/cancelButton"
            android:layout_width="120dp"
            android:layout_height="40dp"
            android:layout_marginEnd="20dp"
            android:backgroundTint="@color/attention"
            android:text="← Cancel"
            android:textAllCaps="false"
            android:textColor="@color/primary"
            android:textSize="@dimen/font_text_size"
            android:textStyle="normal" />

        <Button
            android:id="@+id/sampleButton"
            android:layout_width="120dp"
            android:layout_height="40dp"
            android:backgroundTint="@color/primary_container_highlighted"
            android:text="✓ Sample"
            android:textAllCaps="false"
            android:textColor="@color/primary"
            android:textSize="@dimen/font_text_size"
            android:textStyle="normal" />
    </LinearLayout>

    <!-- Spacer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Bottom nav mockup -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/primary_container"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/navRegisteredEvents"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Registered Events"
            android:textColor="@color/black"
            android:textSize="@dimen/font_text_size"
            android:textStyle="normal" />

        <TextView
            android:id="@+id/navEventList"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Event List"
            android:textColor="@color/black"
            android:textSize="@dimen/font_text_size"
            android:textStyle="normal" />

        <TextView
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Profile"
            android:textColor="@color/black"
            android:textSize="@dimen/font_text_size"
            android:textStyle="normal" />
    </LinearLayout>

</LinearLayout>