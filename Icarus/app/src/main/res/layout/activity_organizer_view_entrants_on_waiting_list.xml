<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <TextView
        android:id="@+id/OrganizerEntrantOnWaitingListEventText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:text="Event Name"
        android:textColor="@color/white"
        android:textSize="@dimen/font_super_heading_size"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:id="@+id/OrganizerEntrantOnWaitingListText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="0dp"
        android:gravity="center"
        android:text="Entrant List"
        android:textColor="@color/white"
        android:textSize="@dimen/font_super_heading_size"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/OrganizerEntrantOnWaitingListEventText"/>

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/OrganizerEntrantOnWaitingListFilterBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginHorizontal="16dp"
        app:singleSelection="true"
        app:selectionRequired="true"
        app:layout_constraintTop_toBottomOf="@id/OrganizerEntrantOnWaitingListText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/OrganizerEntrantOnWaitingListFilterBar_waiting"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Waiting"
            android:textColor="@color/white"
            android:backgroundTint="@color/toggle_button_color"
            android:textSize="12sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/OrganizerEntrantOnWaitingListFilterBar_chosen"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Selected"
            android:textColor="@color/white"
            android:backgroundTint="@color/toggle_button_color"
            android:textSize="12sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/OrganizerEntrantOnWaitingListFilterBar_cancelled"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Cancelled"
            android:textColor="@color/white"
            android:backgroundTint="@color/toggle_button_color"
            android:textSize="12sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/OrganizerEntrantOnWaitingListFilterBar_final"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Final"
            android:textColor="@color/white"
            android:backgroundTint="@color/toggle_button_color"
            android:textSize="12sp" />

    </com.google.android.material.button.MaterialButtonToggleGroup>

    <ListView
        android:id="@+id/OrganizerEntrantOnWaitingList"
        android:layout_width="340dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/OrganizerEntrantOnWaitingListFilterBar"
        app:layout_constraintBottom_toTopOf="@id/OrganizerEntrantOnWaitingListBackButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/OrganizerEntrantOnWaitingListBackButton"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginBottom="8dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:text="Go Back"
        android:textSize="@dimen/font_text_size"
        android:backgroundTint="@color/primary_container"
        android:textColor="@color/primary_container_highlighted"
        app:layout_constraintTop_toBottomOf="@id/OrganizerEntrantOnWaitingList"
        app:layout_constraintBottom_toTopOf="@id/nav_bar"
        app:layout_constraintStart_toEndOf="@id/OrganizerEntrantOnWaitingListSelectAllButton"
        app:layout_constraintEnd_toStartOf="@id/OrganizerEntrantOnWaitingListSendNotificationButton"/>
    <Button
        android:id="@+id/OrganizerEntrantOnWaitingListSendNotificationButton"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginBottom="8dp"
        android:layout_marginEnd="8dp"
        android:text="Message all selected"
        android:textSize="@dimen/font_text_size"
        android:backgroundTint="@color/primary_container"
        android:textColor="@color/primary_container_highlighted"
        app:layout_constraintTop_toBottomOf="@id/OrganizerEntrantOnWaitingList"
        app:layout_constraintBottom_toTopOf="@id/nav_bar"
        app:layout_constraintStart_toEndOf="@id/OrganizerEntrantOnWaitingListBackButton"
        app:layout_constraintEnd_toEndOf="parent"/>
    <Button
        android:id="@+id/OrganizerEntrantOnWaitingListSelectAllButton"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginBottom="8dp"
        android:layout_marginStart="8dp"
        android:text="Select All"
        android:textSize="@dimen/font_text_size"
        android:backgroundTint="@color/primary_container"
        android:textColor="@color/primary_container_highlighted"
        app:layout_constraintTop_toBottomOf="@id/OrganizerEntrantOnWaitingList"
        app:layout_constraintBottom_toTopOf="@id/nav_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/OrganizerEntrantOnWaitingListBackButton"/>

    <include
        android:id="@+id/nav_bar"
        layout="@layout/nav_bar"
        android:layout_width="0dp"
        android:layout_height="60dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>