<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal">
    
        <!-- Title for events page-->
        <TextView
            android:id="@+id/entrant_event_list_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="20dp"
            android:text="Icarus Events"
            android:textSize="@dimen/font_super_heading_size"
            android:textStyle="bold" />
    
        <!-- Search Filter -->
        <EditText
            android:id="@+id/entrant_event_list_search_filter"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            android:hint="Search events..."
            android:textSize="@dimen/font_subheading_size"
            android:inputType="text"
            android:maxLines="1" />
    
        <!-- Filter buttons -->
        <Button
            android:id="@+id/entrant_event_list_filter_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            android:text="Filter Events"
            android:textSize="@dimen/font_text_size"
            android:backgroundTint="@color/primary_container_highlighted"
            android:textColor="@color/primary_container" />
    
        <!-- Message for empty list -->
        <TextView
            android:id="@+id/entrant_event_list_empty_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="20dp"
            android:text="@string/entrants_event_list_empty_events"
            android:textSize="@dimen/font_subheading_size"
            android:visibility="gone"
            />
    
    
        <!-- Event list -->
        <ListView
            android:id="@+id/entrant_event_list_view"
            android:layout_width="300dp"
            android:layout_height="0dp"
            android:layout_weight="1" />
    
    </LinearLayout>

    <!-- NAVIGATION BAR -->
    <include
        android:id="@+id/nav_bar"
        layout="@layout/nav_bar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_gravity="bottom" />

</FrameLayout>