<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="16dp">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/admin_dashboard_user_list_image"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:scaleType="centerCrop"
        android:src="@drawable/poster"
        app:shapeAppearance="@style/ShapeAppearanceOverlay.App.CircleImageView" />

    <TextView
        android:id="@+id/admin_dashboard_user_list_user_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="16dp"
        android:text="User Name"
        android:textColor="@color/lightText"
        android:textSize="@dimen/font_subheading_size"
        android:textStyle="bold" />

    <ImageButton
        android:id="@+id/admin_dashboard_user_list_remove_user_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:backgroundTint="?android:attr/windowBackground"
        android:contentDescription="remove_user_button"
        app:srcCompat="@drawable/delete"
        app:tint="@color/attention" />

</LinearLayout>