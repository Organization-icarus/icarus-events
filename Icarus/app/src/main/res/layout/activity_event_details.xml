<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- MAIN CONTENT -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingBottom="60dp" >

        <!-- EVENT POSTER -->
        <ImageView
            android:id="@+id/eventPoster"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_marginTop="32dp"
            android:src="@mipmap/dummy_image" />

        <!-- EVENT NAME -->
        <TextView
            android:id="@+id/eventName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Event Name"
            android:textSize="@dimen/font_heading_size" />

        <!-- EVENT DETAILS LIST -->
        <FrameLayout
            android:id="@+id/eventListFrameLayout"
            android:layout_width="300dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="12dp">

            <ListView
                android:id="@+id/event_details_event_list"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </FrameLayout>

        <!-- LOTTERY GUIDELINES -->
        <TextView
            android:id="@+id/lottery_guidelines"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Lottery Guidelines"
            android:textColor="@color/primary_container_highlighted"
            android:clickable="true"
            android:focusable="true" />

        <!--####################-->
        <!-- DYNAMIC BUTTONS -->
        <!--####################-->
        <LinearLayout
            android:id="@+id/buttonContainer"
            android:layout_width="300dp"
            android:layout_height="70dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp">


            <!--####################-->
            <!-- ADMIN -->
            <!--####################-->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/event_organizer_button"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:padding="0dp"
                android:text="Organizer"
                android:textColor="@color/primary_container_highlighted"
                android:backgroundTint="@color/primary_container"
                app:cornerRadius="0dp"
                app:icon="@drawable/profile"
                app:iconTint="@color/primary_container_highlighted"
                app:iconPadding="8dp"
                app:iconGravity="textStart"
                android:visibility="visible" />


            <!--####################-->
            <!-- ORGANIZER -->
            <!--####################-->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/manage_button"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:padding="0dp"
                android:text="Manage"
                android:textSize="@dimen/font_text_size"
                android:textColor="@color/primary_container_highlighted"
                android:backgroundTint="@color/primary_container"
                app:cornerRadius="0dp"
                app:icon="@drawable/gear"
                app:iconTint="@color/primary_container_highlighted"
                app:iconPadding="8dp"
                app:iconGravity="textStart"
                android:visibility="gone" />


            <!--####################-->
            <!--ADMIN AND ORGANIZER -->
            <!--####################-->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/alerts_button"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:padding="0dp"
                android:text="Alerts"
                android:textColor="@color/primary_container_highlighted"
                android:backgroundTint="@color/primary_container"
                app:cornerRadius="0dp"
                app:icon="@drawable/notifications"
                app:iconTint="@color/primary_container_highlighted"
                app:iconPadding="8dp"
                app:iconGravity="textStart"
                android:visibility="visible" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/delete_button"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:padding="0dp"
                android:text="Delete"
                android:textSize="@dimen/font_text_size"
                android:textColor="@color/primary_container_highlighted"
                android:backgroundTint="@color/primary_container"
                app:cornerRadius="0dp"
                app:icon="@drawable/delete"
                app:iconTint="@color/primary_container_highlighted"
                app:iconPadding="8dp"
                app:iconGravity="textStart"
                android:visibility="visible" />


            <!--####################-->
            <!-- USER -->
            <!--####################-->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/join_waiting_list"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="Join Waiting List"
                android:textSize="@dimen/font_text_size"
                android:textColor="@color/primary_container_highlighted"
                android:backgroundTint="@color/primary_container"
                app:icon="@drawable/check"
                app:iconTint="@color/primary_container_highlighted"
                app:iconGravity="textStart"
                android:visibility="gone"/>

        </LinearLayout>

    </LinearLayout>

    <!-- NAVIGATION BAR -->
    <include
    android:id="@+id/nav_bar"
    layout="@layout/nav_bar"
    android:layout_width="match_parent"
    android:layout_height="60dp"
    android:layout_gravity="bottom" />

</FrameLayout>