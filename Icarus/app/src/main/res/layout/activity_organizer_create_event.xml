<?xml version="1.0" encoding="utf-8"?>

<!--
    activity_organizer_create_event.xml
    Author: Ben Salmon

    AI was used the creation of the cards. Not in the buttons, editTexts, imageViews, or spinners.
    Claude AI, March 22,2026 "How can I separate a XML file into separate cards that
    will make the screen more visually pleasing for users. What is the layout for cards and how
    they used?"
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:id="@+id/OrganizerCreateEventTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:text="Create Event"
        android:textColor="@color/black"
        android:textSize="@dimen/font_super_heading_size"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@+id/OrganizerCreateEventTitle"
        app:layout_constraintBottom_toTopOf="@+id/nav_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Image -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/OrganizerCreateEventImageCard"
                style="@style/ViewCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp">

                    <ImageView
                        android:id="@+id/OrganizerCreateEventImage"
                        android:layout_width="180dp"
                        android:layout_height="180dp"
                        android:src="@drawable/poster"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"/>

                    <Button
                        android:id="@+id/OrganizerCreateEventUploadPosterButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:backgroundTint="@color/primary_container"
                        android:text="Upload Event Image"
                        android:textSize="@dimen/font_text_size"
                        android:textColor="@color/primary_container_highlighted"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/OrganizerCreateEventImage"/>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Name and Description -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/OrganizerCreateEventDetailsCard"
                style="@style/ViewCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="12dp"
                app:layout_constraintTop_toBottomOf="@id/OrganizerCreateEventImageCard"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/OrganizerCreateEventDetailsLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Event Details"
                        android:textSize="@dimen/font_subheading_size"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"/>

                    <EditText
                        android:id="@+id/OrganizerCreateEventEventTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:hint="Event Name"
                        android:inputType="textCapWords"
                        android:textColor="@color/black"
                        android:textSize="@dimen/font_heading_size"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/OrganizerCreateEventDetailsLabel"/>

                    <EditText
                        android:id="@+id/OrganizerCreateEventDescription"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:hint="Event Description"
                        android:inputType="textMultiLine"
                        android:minLines="4"
                        android:gravity="top"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/OrganizerCreateEventEventTitle"/>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Location and Geolocation -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/OrganizerCreateEventLocationCard"
                style="@style/ViewCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="12dp"
                app:layout_constraintTop_toBottomOf="@id/OrganizerCreateEventDetailsCard"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/OrganizerCreateEventLocationLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Location"
                        android:textSize="@dimen/font_subheading_size"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"/>

                    <EditText
                        android:id="@+id/OrganizerCreateEventEventLocation"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_marginEnd="8dp"
                        android:hint="Event Location"
                        android:inputType="textCapWords"
                        android:textColor="@color/black"
                        android:textSize="@dimen/font_heading_size"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/OrganizerCreateEventGeolocationSwitch"
                        app:layout_constraintTop_toBottomOf="@id/OrganizerCreateEventLocationLabel"/>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/OrganizerCreateEventGeolocationSwitch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Geolocation"
                        android:textSize="@dimen/font_subheading_size"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/OrganizerCreateEventEventLocation"
                        app:layout_constraintBottom_toBottomOf="@id/OrganizerCreateEventEventLocation"/>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Participants and Category -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/OrganizerCreateEventSettingsCard"
                style="@style/ViewCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="12dp"
                app:layout_constraintTop_toBottomOf="@id/OrganizerCreateEventLocationCard"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/OrganizerCreateEventSettingsLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Event Settings"
                        android:textSize="@dimen/font_subheading_size"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"/>

                    <EditText
                        android:id="@+id/OrganizerCreateEventLimitWaitingListLimit"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:hint="Enter Limit of the Waiting List"
                        android:inputType="numberDecimal"
                        android:textColor="@color/black"
                        android:textSize="@dimen/font_heading_size"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/OrganizerCreateEventSettingsLabel"/>

                    <Spinner
                        android:id="@+id/OrganizerCreateEventCategory"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:padding="12dp"
                        android:backgroundTint="@color/primary_container"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/OrganizerCreateEventLimitWaitingListLimit"/>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Registration Start -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/OrganizerCreateEventRegStartCard"
                style="@style/ViewCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/OrganizerCreateEventSettingsCard"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/OrganizerCreateEventShowRegPeriodStart"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Registration Start Date and Time"
                        android:textSize="@dimen/font_subheading_size"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"/>

                    <Button
                        android:id="@+id/OrganizerCreateEventRegistrationPeriodStartDate"
                        android:layout_width="170dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_marginEnd="4dp"
                        android:text="Set Date"
                        android:textSize="@dimen/font_text_size"
                        android:backgroundTint="@color/primary_container"
                        android:textColor="@color/primary_container_highlighted"
                        app:layout_constraintTop_toBottomOf="@id/OrganizerCreateEventShowRegPeriodStart"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/OrganizerCreateEventRegistrationPeriodStartTime"/>

                    <Button
                        android:id="@+id/OrganizerCreateEventRegistrationPeriodStartTime"
                        android:layout_width="170dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_marginStart="4dp"
                        android:text="Set Time"
                        android:textSize="@dimen/font_text_size"
                        android:backgroundTint="@color/primary_container"
                        android:textColor="@color/primary_container_highlighted"
                        app:layout_constraintTop_toBottomOf="@id/OrganizerCreateEventShowRegPeriodStart"
                        app:layout_constraintStart_toEndOf="@id/OrganizerCreateEventRegistrationPeriodStartDate"
                        app:layout_constraintEnd_toEndOf="parent"/>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Registration End -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/OrganizerCreateEventRegEndCard"
                style="@style/ViewCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="0dp"
                app:layout_constraintTop_toBottomOf="@id/OrganizerCreateEventRegStartCard"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/OrganizerCreateEventShowRegPeriodEnd"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Registration End Date and Time"
                        android:textSize="@dimen/font_subheading_size"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"/>

                    <Button
                        android:id="@+id/OrganizerCreateEventRegistrationPeriodEndDate"
                        android:layout_width="170dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_marginEnd="4dp"
                        android:text="Set Date"
                        android:textSize="@dimen/font_text_size"
                        android:backgroundTint="@color/primary_container"
                        android:textColor="@color/primary_container_highlighted"
                        app:layout_constraintTop_toBottomOf="@id/OrganizerCreateEventShowRegPeriodEnd"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/OrganizerCreateEventRegistrationPeriodEndTime"/>

                    <Button
                        android:id="@+id/OrganizerCreateEventRegistrationPeriodEndTime"
                        android:layout_width="170dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_marginStart="4dp"
                        android:text="Set Time"
                        android:textSize="@dimen/font_text_size"
                        android:backgroundTint="@color/primary_container"
                        android:textColor="@color/primary_container_highlighted"
                        app:layout_constraintTop_toBottomOf="@id/OrganizerCreateEventShowRegPeriodEnd"
                        app:layout_constraintStart_toEndOf="@id/OrganizerCreateEventRegistrationPeriodEndDate"
                        app:layout_constraintEnd_toEndOf="parent"/>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Event Date -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/OrganizerCreateEventDateCard"
                style="@style/ViewCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="0dp"
                app:layout_constraintTop_toBottomOf="@id/OrganizerCreateEventRegEndCard"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/OrganizerCreateEventShowEventDateTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Event Date and Time"
                        android:textSize="@dimen/font_subheading_size"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"/>

                    <Button
                        android:id="@+id/OrganizerCreateEventDate"
                        android:layout_width="170dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_marginEnd="4dp"
                        android:text="Set Date"
                        android:textSize="@dimen/font_text_size"
                        android:backgroundTint="@color/primary_container"
                        android:textColor="@color/primary_container_highlighted"
                        app:layout_constraintTop_toBottomOf="@id/OrganizerCreateEventShowEventDateTitle"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/OrganizerCreateEventTime"/>

                    <Button
                        android:id="@+id/OrganizerCreateEventTime"
                        android:layout_width="170dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_marginStart="4dp"
                        android:text="Set Time"
                        android:textSize="@dimen/font_text_size"
                        android:backgroundTint="@color/primary_container"
                        android:textColor="@color/primary_container_highlighted"
                        app:layout_constraintTop_toBottomOf="@id/OrganizerCreateEventShowEventDateTitle"
                        app:layout_constraintStart_toEndOf="@id/OrganizerCreateEventDate"
                        app:layout_constraintEnd_toEndOf="parent"/>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Create Event Button -->
            <Button
                android:id="@+id/OrganizerCreateEventCreateEvent"
                android:layout_width="300dp"
                android:layout_height="60dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="24dp"
                android:text="Create Event"
                android:textSize="@dimen/font_text_size"
                android:backgroundTint="@color/primary_container"
                android:textColor="@color/primary_container_highlighted"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/OrganizerCreateEventDateCard"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>

    <include
        android:id="@+id/nav_bar"
        layout="@layout/nav_bar"
        android:layout_width="0dp"
        android:layout_height="60dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>