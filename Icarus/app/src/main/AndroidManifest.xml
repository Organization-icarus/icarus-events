<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="andriod.permission.INTERNET" />
    <uses-permission android:name="andriod.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        tools:replace="android:fullBackupContent"
        android:icon="@mipmap/ic_launcher"
        android:label="Icarus"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Icarus">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".EntrantEventListActivity" />

        <activity android:name=".OrganizerCreateEventActivity" />

        <activity android:name=".UserRegistrationActivity" />

        <activity android:name=".UserSettingsActivity" />

        <activity android:name=".AdministratorDashboardActivity" />

        <activity android:name=".UserProfileActivity" />

        <activity android:name=".EventHistoryActivity" />

        <activity android:name=".EventDetailsActivity" />

        <activity android:name=".OrganizerViewEntrantsOnWaitingListActivity"/>

        <activity android:name=".OrganizerManageEventActivity"/>

        <activity android:name=".SampleAttendeesActivity"/>

        <activity android:name=".EntrantMapActivity"/>

    </application>

</manifest>