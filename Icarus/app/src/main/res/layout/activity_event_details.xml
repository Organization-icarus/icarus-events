<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- MAIN CONTENT -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:clipToPadding="false"
            android:gravity="center_horizontal">

            <!-- EVENT POSTER -->
            <ImageView
                android:id="@+id/eventPoster"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:scaleType="centerCrop"
                android:layout_marginTop="32dp"
                android:src="@drawable/poster" />

            <!-- EVENT NAME -->
            <TextView
                android:id="@+id/eventName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Event Name"
                android:textSize="@dimen/font_heading_size"
                android:layout_marginTop="16dp" />

            <!-- EVENT DESCRIPTION -->
            <TextView
                android:id="@+id/eventDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/paragraph_placeholder"
                android:textSize="@dimen/font_text_size" />

            <!-- DIVIDER -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginTop="16dp" />

            <!-- EVENT DETAILS LIST -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/event_details_event_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

            <!-- LOTTERY GUIDELINES -->
            <TextView
                android:id="@+id/lottery_guidelines"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Lottery Guidelines"
                android:textColor="@color/primary_container_highlighted"
                android:clickable="true"
                android:focusable="true" />


            <!--####################-->
            <!-- ADMIN -->
            <!--####################-->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/event_organizer_button"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:padding="0dp"
                android:text="Organizer"
                android:textColor="@color/primary_container_highlighted"
                android:backgroundTint="@color/primary_container"
                app:cornerRadius="0dp"
                app:icon="@drawable/profile"
                app:iconTint="@color/primary_container_highlighted"
                app:iconPadding="8dp"
                app:iconGravity="textStart"
                android:visibility="gone" />


            <!--####################-->
            <!-- ORGANIZER -->
            <!--####################-->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/manage_button"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:padding="0dp"
                android:text="Manage"
                android:textSize="@dimen/font_text_size"
                android:textColor="@color/primary_container_highlighted"
                android:backgroundTint="@color/primary_container"
                app:cornerRadius="0dp"
                app:icon="@drawable/gear"
                app:iconTint="@color/primary_container_highlighted"
                app:iconPadding="8dp"
                app:iconGravity="textStart"
                android:visibility="gone" />


            <!--####################-->
            <!--ADMIN AND ORGANIZER -->
            <!--####################-->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/notification_button"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:padding="0dp"
                android:text="Alerts"
                android:textColor="@color/primary_container_highlighted"
                android:backgroundTint="@color/primary_container"
                app:cornerRadius="0dp"
                app:icon="@drawable/notifications"
                app:iconTint="@color/primary_container_highlighted"
                app:iconPadding="8dp"
                app:iconGravity="textStart"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/delete_button"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:padding="0dp"
                android:text="Delete"
                android:textSize="@dimen/font_text_size"
                android:textColor="@color/primary_container_highlighted"
                android:backgroundTint="@color/primary_container"
                app:cornerRadius="0dp"
                app:icon="@drawable/delete"
                app:iconTint="@color/primary_container_highlighted"
                app:iconPadding="8dp"
                app:iconGravity="textStart"
                android:visibility="gone" />


            <!--####################-->
            <!-- USER UNINITIALIZED -->
            <!--####################-->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/join_waiting_list_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Join Waiting List"
                android:textSize="@dimen/font_text_size"
                android:textColor="@color/primary_container_highlighted"
                android:backgroundTint="@color/primary_container"
                app:icon="@drawable/check"
                app:iconTint="@color/primary_container_highlighted"
                app:iconGravity="textStart"
                android:visibility="gone"/>


            <!--####################-->
            <!-- USER WAITING -->
            <!--####################-->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/leave_waiting_list_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Leave Waiting List"
                android:textSize="@dimen/font_text_size"
                android:textColor="@color/primary_container_highlighted"
                android:backgroundTint="@color/primary_container"
                app:icon="@drawable/check"
                app:iconTint="@color/primary_container_highlighted"
                app:iconGravity="textStart"
                android:visibility="gone"/>

            <!--####################-->
            <!-- USER SELECTED OR REGISTERED -->
            <!--####################-->
            <!-- TODO: make both of these buttons have the same width -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/decline_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="Decline"
                android:textSize="@dimen/font_text_size"
                android:textColor="@color/primary_container_highlighted"
                android:backgroundTint="@color/primary_container"
                app:icon="@drawable/decline"
                app:iconTint="@color/primary_container_highlighted"
                app:iconGravity="textStart"
                android:visibility="visible"/>


            <!--####################-->
            <!-- USER SELECTED -->
            <!--####################-->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/register_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Register"
                android:textSize="@dimen/font_text_size"
                android:textColor="@color/primary_container_highlighted"
                android:backgroundTint="@color/primary_container"
                app:icon="@drawable/check"
                app:iconTint="@color/primary_container_highlighted"
                app:iconGravity="textStart"
                android:visibility="visible"/>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- NAVIGATION BAR -->
    <include
        android:id="@+id/nav_bar"
        layout="@layout/nav_bar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_gravity="bottom"/>

</FrameLayout>